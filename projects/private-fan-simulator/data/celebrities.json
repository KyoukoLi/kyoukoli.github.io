// 游戏开始时的随机选择
window.getRandomCelebrity = function() {
  const pool = window.CELEBRITY_POOL;
  // 不同难度加权
  const weights = pool.map(c => {
    switch (c.difficulty) {
      case 'extreme': return 1;
      case 'hard': return 2;
      case 'medium': return 3;
      case 'easy': return 2;
      default: return 1;
    }
  });
  
  const totalWeight = weights.reduce((a, b) => a + b, 0);
  let random = Math.random() * totalWeight;
  
  for (let i = 0; i < pool.length; i++) {
    random -= weights[i];
    if (random <= 0) return pool[i];
  }
  
  return pool[0];
};
